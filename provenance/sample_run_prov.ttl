<http://example.org/oskg/resource/entity/corpus> a prov:Entity ;
    rdfs:label "Corpus of open-access PDF papers" ;
    prov:atLocation "data/papers/" .

<http://example.org/oskg/resource/entity/grants> a prov:Entity ;
